
CC = gcc
LDFLAGS = -g -lm
CFLAGS= -Wall


all: main-static

# Local Libraries
MYLIB = mylib.a

main-static: main.o $(MYLIB)
	$(CC) main.o $(MYLIB) -o main-static

$(MYLIB): $(MYLIB)(hello.o) $(MYLIB)(here.o) $(MYLIB)(bye.o)
main.o: main.c mylib.h
hello.o: hello.c mylib.h
here.o: here.c mylib.h
bye.o: bye.c mylib.h


clean:
	rm *.o main-static


