# Compiler
CC = gcc
CFLAGS = -Wall -fPIC   # Adding -fPIC to compile position-independent code
LDFLAGS = -g -lm

# Directories for shared libraries
LIB_DIR = ./lib

# Dynamic Library Name
MYLIB = libmylib.so

# Source and Object Files
SRC = hello.c here.c bye.c
OBJ = hello.o here.o bye.o

# Default target
all: main-dynamic

# Build the main program by linking with the shared library
main-dynamic: main.o $(LIB_DIR)/$(MYLIB)
	$(CC) main.o -L$(LIB_DIR) -lmylib -o main-dynamic

# Build the shared library (ensure the lib directory exists)
$(LIB_DIR)/$(MYLIB): $(OBJ) | $(LIB_DIR)
	$(CC) -shared -o $(LIB_DIR)/$(MYLIB) $(OBJ)

# Compile object files with -fPIC
hello.o: hello.c mylib.h
	$(CC) $(CFLAGS) -c hello.c

here.o: here.c mylib.h
	$(CC) $(CFLAGS) -c here.c

bye.o: bye.c mylib.h
	$(CC) $(CFLAGS) -c bye.c

main.o: main.c mylib.h
	$(CC) $(CFLAGS) -c main.c

# Create the lib directory if not exists
$(LIB_DIR):
	mkdir -p $(LIB_DIR)

# Clean command to remove generated files
clean:
	rm -f *.o main-dynamic $(LIB_DIR)/$(MYLIB)

.PHONY: all clean

